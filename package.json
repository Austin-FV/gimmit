{
  "name": "gimmit",
  "displayName": "gimmit",
  "description": "Generate conventional commits from your changed files in VS Code, with optional AI-powered descriptions.",
  "version": "1.0.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gimmit.open",
        "title": "Gimmit: Open"
      },
      {
        "command": "gimmit.setApiKey",
        "title": "Gimmit: Set API Key"
      },
      {
        "command": "gimmit.manageApiKey",
        "title": "Gimmit: Manage API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gimmit",
          "title": "Gimmit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gimmit": [
        {
          "type": "webview",
          "id": "gimmit.sidebar",
          "name": "gimmit",
          "when": "true",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "publisher": "austinfv",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0d0f14",
    "theme": "dark"
  },
  "keywords": [
    "git",
    "commit",
    "conventional commits",
    "conventional commit",
    "commit message",
    "git commit",
    "ai",
    "productivity",
    "developer tools",
    "source control",
    "scm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Austin-FV/gimmit"
  },
  "bugs": {
    "url": "https://github.com/Austin-FV/gimmit/issues"
  },
  "homepage": "https://github.com/Austin-FV/gimmit#readme",
  "license": "MIT"
}