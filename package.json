{
  "name": "gimmit",
  "displayName": "gimmit",
  "description": "Select modified files and generate conventional commit commands — live updating sidebar.",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gimmit.open",
        "title": "gimmit: Open Sidebar"
      }
    ],
    "views": {
      "scm": [
        {
          "type": "webview",
          "id": "gimmit.sidebar",
          "name": "gimmit",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}