{
  "name": "gimmit",
  "displayName": "gimmit",
  "description": "Generate conventional commit commands from your changed files.",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gimmit.open",
        "title": "gimmit: Open"
      }
    ],"viewsContainers": {
      "activitybar": [
        {
          "id": "gimmit",
          "title": "gimmit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "gimmit": [
        {
          "type": "webview",
          "id": "gimmit.sidebar",
          "name": "gimmit",
          "when": "true",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "publisher": "your-publisher-id",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0d0f14",
    "theme": "dark"
  },
  "keywords": ["git", "commit", "conventional commits", "scm"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Austin-FV/gimmit"
  },
  "bugs": {
    "url": "https://github.com/Austin-FV/gimmit/issues"
  },
  "homepage": "https://github.com/Austin-FV/gimmit#readme",
  "license": "MIT"
}